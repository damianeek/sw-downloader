# ── Channel ────────────────────────────────────────────────────────────────────
# YouTube channel handle (without @)
CHANNEL_HANDLE=stan_wyjatkowy

# ── Output ─────────────────────────────────────────────────────────────────────
# Where downloaded videos are saved
OUTPUT_DIR=/downloads

# Where the state file and debug screenshots are stored
STATE_FILE=/config/state.json

# Temp directory for yt-dlp partial files during download.
# On Linux /tmp is RAM-backed (tmpfs) by default — fast and auto-cleaned.
# Override if your RAM is limited or you want to use a specific fast disk.
TEMP_DIR=/tmp/sw-dl

# Set to true to generate a Plex-compatible .nfo sidecar file next to each
# downloaded video (title, description, aired date, thumbnail).
GENERATE_NFO=false

# Set to true to download Polish subtitles and embed them as an internal
# subtitle track in the MP4. Tries manual subs first, falls back to auto-generated.
DOWNLOAD_SUBTITLES=false

# ── Binaries ───────────────────────────────────────────────────────────────────
# Full path to yt-dlp binary (leave empty to use PATH)
YTDLP_BIN=yt-dlp

# Full path to ffmpeg binary — passed to yt-dlp via --ffmpeg-location
# Required if ffmpeg is not in PATH (bundled inside Docker at /usr/bin/ffmpeg)
FFMPEG_LOCATION=

# ── Filename ───────────────────────────────────────────────────────────────────
# Year the show premiered — used in filenames:
#   "Stan Wyjątkowy (2022) - 2026-03-14 - Title [id].mp4"
# Set to empty to use yt-dlp default: "Uploader - Title [id].mp4"
SHOW_YEAR=2022

# ── Detection thresholds ───────────────────────────────────────────────────────
# Max age of a video (in hours) to be considered the unedited stream.
MAX_AGE_HOURS=12

# Minimum video duration in minutes to be considered the unedited stream.
MIN_DURATION_MINUTES=60

# ── Schedule ───────────────────────────────────────────────────────────────────
# Timezone for all cron jobs
TIMEZONE=Europe/Warsaw

# Initial check: when to first look for the stream
# Default: Saturday 20:05
FIND_CRON=5 20 * * 6

# Retry check: how often to keep looking if stream not found yet
# Default: every 5 min, Saturday 20:00–23:59
FIND_RETRY_CRON=*/5 20-23 * * 6

# How often to attempt the download once the stream URL is found
# Default: every 30 minutes
DOWNLOAD_CRON=*/30 * * * *

# ── Debug ──────────────────────────────────────────────────────────────────────
# Set to true to run both jobs immediately instead of waiting for cron
RUN_NOW=false

# Set to false to show the Playwright browser window (local debugging only)
HEADLESS=true
